# Copy to .env and fill in. .env is gitignored.

# Polygon.io — Stocks Advanced (subscribe Week 1)
POLYGON_API_KEY=

# Finnhub — earnings calendar (free tier)
FINNHUB_API_KEY=

# Alpaca — paper trading (Phase 6)
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# MLflow tracking server
MLFLOW_TRACKING_URI=http://localhost:5000

# DuckDB / data lake root (point to local SSD or VPS volume)
DATA_LAKE_ROOT=./data

# Optional — research-helper LLM API
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
